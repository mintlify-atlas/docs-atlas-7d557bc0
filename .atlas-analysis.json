  "keyFeatures": [
    "Tiered KV cache with hot (RAM) and cold (SSD) tiers using block-based paged cache management",
    "Continuous batching via mlx-lm BatchGenerator for high-concurrency inference",
    "Multi-model serving with LRU eviction, model pinning, and per-model TTL",
    "Vision-language model (VLM) support with multi-image inputs and tool calling",
    "OpenAI and Anthropic API compatibility as a drop-in replacement",
    "macOS menubar app for managing the server without a terminal",
    "Built-in web admin dashboard with chat UI, model downloader, and benchmarks",
    "MCP (Model Context Protocol) tool integration",
    "One-click integrations for Claude Code, Codex, OpenClaw, and Pi",
    "Audio support (TTS, STT, STS) via mlx-audio"
  ],
  "publicApiSurface": [
    "POST /v1/chat/completions — OpenAI-compatible chat completions with streaming",
    "POST /v1/completions — Text completions with streaming",
    "POST /v1/messages — Anthropic Messages API",
    "POST /v1/responses — OpenAI Responses API (Codex compatibility)",
    "POST /v1/embeddings — Text embeddings",
    "POST /v1/rerank — Document reranking",
    "GET /v1/models — List available models with load status",
    "GET /health — Health check",
    "GET /v1/mcp/tools — List MCP tools",
    "GET /v1/mcp/servers — MCP server status",
    "POST /v1/mcp/execute — Execute MCP tool",
    "omlx serve — Start the multi-model inference server",
    "omlx launch <tool> — Launch an external tool with oMLX integration",
    "omlx diagnose menubar — Diagnose menubar visibility issues"
  ]
}
